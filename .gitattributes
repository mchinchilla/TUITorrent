# Auto-detect text files and normalize line endings
* text=auto

# Source code
*.cs text diff=csharp
*.csproj text
*.slnx text
*.sln text

# Configuration
*.json text
*.xml text
*.yml text
*.yaml text
*.toml text

# Documentation
*.md text diff=markdown
*.txt text

# Shell scripts
*.sh text eol=lf

# Windows scripts
*.cmd text eol=crlf
*.bat text eol=crlf
*.ps1 text eol=crlf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.torrent binary
